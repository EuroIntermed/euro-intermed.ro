---
/**
 * Section — vertical rhythm wrapper with tone variants.
 *   default   → page ground
 *   raised    → subtle raised surface
 *   contrast  → deep green band with light text (reversed accents)
 */
interface Props {
  id?: string
  tone?: 'default' | 'raised' | 'contrast'
  labelledby?: string
  class?: string
}
const { id, tone = 'default', labelledby, class: className = '' } = Astro.props
---

<section
  id={id}
  class={`ei-section ei-section--${tone} ${className}`.trim()}
  aria-labelledby={labelledby}
>
  <div class="ei-container">
    <slot />
  </div>
</section>

<style>
  .ei-section {
    padding-block: clamp(3.5rem, 2.2rem + 5vw, 7rem);
    position: relative;
  }
  .ei-section--raised {
    background: var(--ei-surface-raised);
    border-block: 1px solid var(--ei-hairline);
  }
  .ei-section--contrast {
    background: var(--ei-surface-contrast);
    color: var(--ei-on-contrast);
  }
  .ei-section--contrast :global(h2),
  .ei-section--contrast :global(h3) {
    color: var(--ei-on-contrast);
  }
  .ei-section--contrast :global(.ei-eyebrow) {
    color: var(--ei-gold);
  }
  .ei-section--contrast :global(.ei-lead) {
    color: var(--ei-on-contrast-muted);
  }
</style>
