---
/**
 * Widget — the Euro-Intermed AI chat widget embed. The widget is always
 * rendered; only its origin (WIDGET_BASE_URL) comes from env, nothing is
 * hardcoded. This is the Astro re-implementation of the WIDGET block that
 * build.mjs used to template.
 *
 * The backend API URL is baked into widget.js at build time (frontend's
 * VITE_API_URL) — we deliberately do NOT pass apiUrl here so that single source
 * of truth is preserved. The router vertical "euro-intermed" + intent "triage"
 * lets the agent classify the inbound need and route into the concrete flow.
 */
import type { Locale } from '../i18n/ui'
import { widgetBaseUrl } from '../lib/config'
import { localizePath } from '../i18n/utils'
const { locale } = Astro.props as { locale: Locale }
const privacyUrl = localizePath('/confidentialitate', locale)
---

{
  (
    <>
      <script is:inline src={`${widgetBaseUrl}/widget.js`} defer />
      <script
        is:inline
        define:vars={{ lang: locale, privacyUrl, accent: '#1f6e4c', accentText: '#ffffff' }}
      >
        {`
        // Poll for the deferred widget bundle instead of bailing on a single
        // DOMContentLoaded check: widget.js loads with 'defer', so AngrosistChat
        // may not exist yet when this inline script runs. Retry (up to ~10s) until
        // init is available, then mount the floating launcher exactly once. Router
        // vertical: the triage agent classifies the inbound need and re-routes the
        // conversation into the concrete flow.
        (function () {
          var cfg = {
            vertical: 'euro-intermed',
            intent: 'triage',
            lang: lang,
            privacyUrl: privacyUrl,
            accent: accent,
            accentText: accentText
          };
          var n = 0;
          (function go() {
            if (window.AngrosistChat && window.AngrosistChat.init) {
              window.AngrosistChat.init(cfg);
              return;
            }
            if (n++ < 200) setTimeout(go, 50);
          })();
        })();
      `}
      </script>
    </>
  )
}
