---
/**
 * Hero — the hub's flagship opener. Layered abstract background (mesh glow +
 * topographic contour + a very faint grayscale ribbon wash from
 * /textures/hero.webp), a badge with pulsing dot, staggered fadeUp headline +
 * lead, primary/secondary actions, a row of trust chips, and the animated
 * HeroFlow network diagram framed in a soft surface panel.
 */
import { t } from '../i18n/utils'
import type { Locale } from '../i18n/ui'
import { waLink } from '../lib/config'
import Button from './Button.astro'
import Icon from './Icon.astro'
import HeroFlow from './HeroFlow.astro'

const { locale } = Astro.props as { locale: Locale }
const c = t(locale).hero
const chipIcons = ['check', 'lock', 'spark']
---

<section class="ei-hero" aria-labelledby="ei-hero-title">
  <div class="ei-hero__glow" aria-hidden="true"></div>
  <div class="ei-hero__wash" aria-hidden="true"></div>
  <svg
    class="ei-hero__contour"
    viewBox="0 0 1200 620"
    preserveAspectRatio="xMidYMid slice"
    fill="none"
    stroke="currentColor"
    stroke-width="1.2"
    aria-hidden="true"
  >
    <path d="M-40 90 C 220 30 420 150 660 96 S 1040 40 1250 108" />
    <path d="M-40 162 C 220 104 420 224 660 168 S 1040 112 1250 180" />
    <path d="M-40 236 C 200 176 440 300 660 240 S 1060 182 1250 252" />
    <path d="M-40 312 C 220 250 420 372 660 314 S 1040 256 1250 326" />
    <path d="M-40 388 C 200 330 440 448 660 392 S 1060 330 1250 402" />
    <path d="M-40 464 C 220 402 420 524 660 466 S 1040 408 1250 478" />
    <path d="M-40 540 C 200 482 440 598 660 544 S 1060 484 1250 552" />
  </svg>

  <div class="ei-container ei-hero__grid">
    <div class="ei-hero__content">
      <p class="ei-badge" data-hero style="--i:0">
        <span class="ei-badge__dot" aria-hidden="true"></span>
        {c.badge}
      </p>
      <h1 class="ei-hero__title" id="ei-hero-title" data-hero style="--i:1">{c.title}</h1>
      <p class="ei-lead ei-hero__lead" data-hero style="--i:2">{c.lead}</p>
      <div class="ei-hero__actions" data-hero style="--i:3">
        <Button href={waLink(c.whatsappText)} variant="whatsapp" target="_blank" rel="noopener" data-ga-vertical="whatsapp">
          {c.whatsapp}
        </Button>
        <Button href="#ecosystem" variant="secondary">{c.secondary}</Button>
      </div>
      <ul class="ei-hero__chips" data-hero style="--i:4">
        {
          c.trustChips.map((chip, i) => (
            <li class="ei-hero__chip">
              <Icon name={chipIcons[i] ?? 'check'} size={16} />
              {chip}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="ei-hero__visual" data-hero style="--i:2">
      <div class="ei-hero__viz">
        <div class="ei-hero__viz-wash" aria-hidden="true"></div>
        <svg
          class="ei-hero__viz-contour"
          viewBox="0 0 400 400"
          preserveAspectRatio="xMidYMid slice"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
          aria-hidden="true"
        >
          <path d="M-20 70 C 90 30 150 120 220 78 S 360 30 420 96" />
          <path d="M-20 150 C 90 108 150 200 220 158 S 360 110 420 176" />
          <path d="M-20 232 C 90 188 150 282 220 238 S 360 190 420 256" />
          <path d="M-20 314 C 90 268 150 362 220 318 S 360 270 420 336" />
        </svg>
        <HeroFlow locale={locale} />
      </div>
    </div>
  </div>
</section>

<style>
  .ei-hero {
    position: relative;
    padding-block: clamp(2.6rem, 1.6rem + 6vw, 6rem) clamp(3.5rem, 2.5rem + 6vw, 7rem);
    overflow: hidden;
    isolation: isolate;
  }

  /* --- Layered abstract background ------------------------------------- */
  .ei-hero__glow {
    position: absolute;
    inset: -30% -20% auto -20%;
    height: 120%;
    z-index: -3;
    pointer-events: none;
    background:
      radial-gradient(38% 46% at 82% 8%, var(--ei-glow), transparent 70%),
      radial-gradient(34% 40% at 12% 2%, var(--ei-gold-soft), transparent 72%),
      radial-gradient(46% 56% at 60% 108%, var(--ei-accent-soft), transparent 62%);
    filter: blur(4px);
  }
  /* Grayscale ribbon wash from the shipped WebP texture — kept very faint,
     accent-tinted via soft-light, masked to fade toward the lower-left. */
  .ei-hero__wash {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background: url('/textures/hero.webp') no-repeat right -6% top -12% / clamp(520px, 68vw, 1000px) auto;
    opacity: 0.07;
    mix-blend-mode: soft-light;
    -webkit-mask-image: radial-gradient(120% 120% at 82% 6%, #000 8%, transparent 66%);
    mask-image: radial-gradient(120% 120% at 82% 6%, #000 8%, transparent 66%);
  }
  .ei-hero__contour {
    position: absolute;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    pointer-events: none;
    color: var(--ei-ink);
    opacity: 0.05;
  }
  :root[data-theme='dark'] .ei-hero__wash,
  :root:not([data-theme='light']) .ei-hero__wash {
    opacity: 0.1;
  }
  :root[data-theme='dark'] .ei-hero__contour,
  :root:not([data-theme='light']) .ei-hero__contour {
    color: var(--ei-accent);
    opacity: 0.09;
  }

  .ei-hero__grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(2rem, 1rem + 4vw, 4.5rem);
  }
  .ei-hero__content {
    max-width: 38rem;
  }
  .ei-hero__title {
    margin-top: 1.1rem;
  }
  .ei-hero__lead {
    margin-top: 1.3rem;
  }
  .ei-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  /* Trust chips */
  .ei-hero__chips {
    list-style: none;
    margin: 1.7rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.4rem;
  }
  .ei-hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ei-muted);
  }
  .ei-hero__chip :global(.ei-ico) {
    color: var(--ei-accent-text);
  }

  /* --- Framed network visual ------------------------------------------- */
  .ei-hero__visual {
    display: flex;
    justify-content: center;
  }
  .ei-hero__viz {
    position: relative;
    width: 100%;
    max-width: 520px;
    padding: clamp(0.9rem, 2.4vw, 1.6rem);
    border-radius: var(--ei-radius-xl);
    border: 1px solid var(--ei-hairline);
    background:
      radial-gradient(120% 120% at 82% 4%, var(--ei-accent-soft), transparent 60%),
      var(--ei-surface);
    box-shadow: var(--ei-shadow-lg);
    overflow: hidden;
    isolation: isolate;
  }
  .ei-hero__viz-wash {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: url('/textures/hero.webp') no-repeat center / cover;
    opacity: 0.08;
    mix-blend-mode: soft-light;
  }
  .ei-hero__viz-contour {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    color: var(--ei-ink);
    opacity: 0.05;
  }
  :root[data-theme='dark'] .ei-hero__viz-contour,
  :root:not([data-theme='light']) .ei-hero__viz-contour {
    color: var(--ei-accent);
    opacity: 0.09;
  }
  .ei-hero__viz :global(.ei-flow) {
    position: relative;
    z-index: 1;
    max-width: 100%;
  }

  /* Hero entrance reveal (fires immediately, not scroll-gated) */
  [data-hero] {
    opacity: 0;
    transform: translateY(24px);
    animation: ei-fade-up 0.8s var(--ei-ease-out) forwards;
    animation-delay: calc(var(--i, 0) * 120ms + 100ms);
  }

  /* Badge with pulsing dot */
  .ei-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    margin: 0;
    padding: 0.45em 0.95em;
    border: 1px solid var(--ei-hairline-strong);
    border-radius: var(--ei-radius-pill);
    background: var(--ei-surface);
    box-shadow: var(--ei-shadow-sm);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--ei-ink-soft);
  }
  .ei-badge__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ei-accent);
    box-shadow: 0 0 0 4px var(--ei-accent-soft);
    animation: ei-badge-dot 2.4s ease-in-out infinite;
  }

  @media (max-width: 880px) {
    .ei-hero__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .ei-hero__visual {
      order: -1;
    }
    .ei-hero__content {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-hero] {
      opacity: 1;
      transform: none;
    }
  }
</style>
