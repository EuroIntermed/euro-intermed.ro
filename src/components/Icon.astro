---
/**
 * Icon — a small, dependency-free line-icon set (2px rounded strokes, 24×24
 * grid) used by the landing feature / step / trust / ecosystem sections so each
 * has a visual anchor. No icon library: every glyph is hand-authored SVG path
 * markup keyed by `name`, inherits `currentColor`, and scales with `size`.
 */
interface Props {
  name: string
  size?: number
  class?: string
}
const { name, size = 24, class: className = '' } = Astro.props

// Inner markup per icon. Stroke attrs live on the <svg> wrapper below.
const paths: Record<string, string> = {
  // single point of contact / routing hub
  hub: '<path d="M12 2v4M12 18v4M2 12h4M18 12h4"/><circle cx="12" cy="12" r="3.2"/><path d="M14.3 9.7 17 7M9.7 14.3 7 17M14.3 14.3 17 17M9.7 9.7 7 7"/>',
  // shield with check — verified company
  shield: '<path d="M12 3l7 3v5c0 4.4-3 7.4-7 9-4-1.6-7-4.6-7-9V6z"/><path d="M9 12l2 2 4-4"/>',
  // chat bubble — whatsapp / assistant
  chat: '<path d="M21 15a2 2 0 0 1-2 2H8l-4 4V5a2 2 0 0 1 2-2h13a2 2 0 0 1 2 2z"/>',
  // globe — europe-wide reach
  globe: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/>',
  // clipboard-check — qualify & verify
  qualify: '<rect x="5" y="4" width="14" height="17" rx="2"/><path d="M9 4V3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1"/><path d="M9 13l2 2 4-4"/>',
  // link — connect
  link: '<path d="M10 13a5 5 0 0 0 7 0l2-2a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-2 2a5 5 0 0 0 7 7l1-1"/>',
  // lock — GDPR
  lock: '<rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>',
  // building — real company
  building: '<rect x="4" y="3" width="16" height="18" rx="2"/><path d="M9 21v-4h6v4M8 7h.01M12 7h.01M16 7h.01M8 11h.01M12 11h.01M16 11h.01"/>',
  // list — angrosist catalogue
  list: '<path d="M8 6h13M8 12h13M8 18h13M3.5 6h.01M3.5 12h.01M3.5 18h.01"/>',
  // box — pallet / clearance
  box: '<path d="M21 8 12 3 3 8v8l9 5 9-5z"/><path d="M3 8l9 5 9-5M12 13v8"/>',
  // bowl — ready-meal / food
  bowl: '<path d="M3 11h18a9 9 0 0 1-18 0z"/><path d="M12 3v3M9 4v2M15 4v2M4 20h16"/>',
  // compass — market entry / skalyou
  compass: '<circle cx="12" cy="12" r="9"/><path d="M15.5 8.5 13 13l-4.5 2.5L11 11z"/>',
  // check — trust chip
  check: '<path d="M20 6 9 17l-5-5"/>',
  // spark / live — verification live
  spark: '<path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8"/>',
  // arrow-right
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
}
const inner = paths[name] ?? ''
---

<svg
  class={`ei-ico ${className}`.trim()}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={inner}
/>
